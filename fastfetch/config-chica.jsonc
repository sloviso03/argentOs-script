{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",

  "logo": {
    "source": "~/.config/fastfetch/logo-chico.txt",
    "color": {
      "1": "red",
      "2": "white"
    }
  },

  "modules": [
    "title",
    {
      "type": "custom",
      "format": "ArgentOs-script por sloviso03"
    },
    "separator",
    "os",
    "host",
    "kernel",
    "uptime",
    "packages",
    "shell",
    "wm",
    "terminal",
    "cpu",
    "memory",
    "disk"
  ]
}
